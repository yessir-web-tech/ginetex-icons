{
  "name": "@yessir/ginetex-care-symbols",
  "version": "1.0.0",
  "description": "Ginetex care symbols font package - Official textile care instruction symbols in modern web font formats",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run test && npm run lint"
  },
  "keywords": [
    "ginetex",
    "care-symbols",
    "textile",
    "font",
    "icons",
    "washing",
    "bleaching",
    "drying",
    "ironing",
    "professional-care",
    "svg",
    "woff",
    "ttf"
  ],
  "author": "YESSIR Organization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yessir-org/ginetex-care-symbols.git"
  },
  "bugs": {
    "url": "https://github.com/yessir-org/ginetex-care-symbols/issues"
  },
  "homepage": "https://github.com/yessir-org/ginetex-care-symbols#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "eslint": "^8.30.0",
    "jest": "^29.3.0",
    "prettier": "^2.8.0"
  },
  "dependencies": {}
}
